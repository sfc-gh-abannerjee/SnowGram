flowchart LR
    S3[("AWS S3<br/>Bucket")]:::awsStyle
    KAFKA[("Kafka Topic<br/>Real-Time")]:::awsStyle
    PIPE_STREAMING[("Snowpipe<br/>Streaming")]:::snowflakeStyle
